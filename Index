<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Job Hunt Tracker</title>
  <style>
    :root{
      --bg:#f5f7fb;
      --card:#ffffff;
      --text:#172033;
      --muted:#667085;
      --line:#e4e7ec;
      --primary:#3559e0;
      --primary-soft:#eef2ff;
      --green:#157f3b;
      --green-soft:#eaf8ef;
      --yellow:#a15c00;
      --yellow-soft:#fff7e6;
      --red:#b42318;
      --red-soft:#fff0ee;
      --shadow:0 10px 30px rgba(24,39,75,.08);
      --radius:18px;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:linear-gradient(180deg,#f8faff 0%,var(--bg) 45%);
      color:var(--text);
    }
    .app{max-width:1400px;margin:0 auto;padding:26px}
    .topbar{
      display:flex;justify-content:space-between;align-items:center;gap:20px;
      margin-bottom:22px;
    }
    .brand h1{margin:0;font-size:30px;letter-spacing:-.5px}
    .brand p{margin:7px 0 0;color:var(--muted)}
    .top-actions{display:flex;flex-wrap:wrap;gap:10px}
    button,.button{
      border:none;border-radius:11px;padding:10px 14px;font-weight:700;cursor:pointer;
      transition:.15s ease;display:inline-flex;align-items:center;justify-content:center;gap:7px;
      text-decoration:none;font-size:14px;
    }
    button:hover,.button:hover{transform:translateY(-1px)}
    .primary{background:var(--primary);color:white}
    .secondary{background:white;color:var(--text);border:1px solid var(--line)}
    .danger{background:var(--red-soft);color:var(--red)}
    .stats{
      display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:14px;margin-bottom:18px;
    }
    .stat{
      background:var(--card);border:1px solid rgba(228,231,236,.8);border-radius:16px;
      padding:17px 18px;box-shadow:var(--shadow)
    }
    .stat .label{color:var(--muted);font-size:13px;font-weight:700}
    .stat .value{font-size:29px;font-weight:800;margin-top:7px}
    .layout{display:grid;grid-template-columns:370px 1fr;gap:18px;align-items:start}
    .panel{
      background:var(--card);border:1px solid rgba(228,231,236,.85);border-radius:var(--radius);
      box-shadow:var(--shadow);padding:20px
    }
    .panel h2{font-size:18px;margin:0 0 4px}
    .panel .sub{color:var(--muted);font-size:13px;margin-bottom:18px;line-height:1.45}
    label{display:block;font-size:12px;font-weight:800;color:#475467;margin:13px 0 6px}
    input,select,textarea{
      width:100%;border:1px solid var(--line);border-radius:10px;padding:11px 12px;
      color:var(--text);background:white;font:inherit;outline:none;
    }
    input:focus,select:focus,textarea:focus{border-color:#9db0ff;box-shadow:0 0 0 4px #eef2ff}
    textarea{min-height:78px;resize:vertical}
    .url-row{display:grid;grid-template-columns:1fr auto;gap:8px}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .form-actions{display:flex;gap:9px;margin-top:17px}
    .form-actions button{flex:1}
    .hint{
      margin-top:10px;background:#f8fafc;border:1px dashed #d0d5dd;border-radius:10px;
      padding:10px;color:var(--muted);font-size:12px;line-height:1.4
    }
    .toolbar{
      display:grid;grid-template-columns:1.3fr .65fr .65fr auto;gap:10px;margin-bottom:14px
    }
    .table-wrap{overflow:auto;border:1px solid var(--line);border-radius:14px}
    table{width:100%;border-collapse:collapse;min-width:1060px}
    th{
      text-align:left;padding:12px;background:#f9fafb;color:#475467;font-size:12px;
      position:sticky;top:0;z-index:1;border-bottom:1px solid var(--line)
    }
    td{padding:12px;border-bottom:1px solid #eef0f3;vertical-align:top;font-size:13px}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:#fcfcfd}
    .company{font-weight:800;font-size:14px}
    .title{font-weight:650;margin-top:3px}
    .meta{color:var(--muted);font-size:12px;margin-top:4px}
    .status{
      display:inline-flex;padding:6px 9px;border-radius:999px;font-size:12px;font-weight:800;
      white-space:nowrap
    }
    .status-Saved{background:#f2f4f7;color:#475467}
    .status-Submitted{background:var(--primary-soft);color:var(--primary)}
    .status-Recruiter{background:var(--yellow-soft);color:var(--yellow)}
    .status-Interview{background:#ecfdf3;color:#027a48}
    .status-Final{background:#f4ebff;color:#6941c6}
    .status-Offer{background:var(--green-soft);color:var(--green)}
    .status-Rejected{background:var(--red-soft);color:var(--red)}
    .status-Withdrawn{background:#f2f4f7;color:#667085}
    .mini-actions{display:flex;gap:6px;flex-wrap:wrap}
    .mini-actions button{
      padding:7px 9px;font-size:12px;background:#f8fafc;color:#344054;border:1px solid var(--line)
    }
    .link{color:var(--primary);font-weight:700;text-decoration:none}
    .empty{text-align:center;color:var(--muted);padding:55px 20px}
    .footer-note{color:var(--muted);font-size:12px;margin-top:12px}
    .toast{
      position:fixed;right:24px;bottom:24px;background:#172033;color:white;padding:12px 15px;
      border-radius:11px;box-shadow:var(--shadow);opacity:0;transform:translateY(10px);
      pointer-events:none;transition:.2s;z-index:20
    }
    .toast.show{opacity:1;transform:translateY(0)}
    @media (max-width:1000px){
      .stats{grid-template-columns:repeat(2,1fr)}
      .layout{grid-template-columns:1fr}
      .toolbar{grid-template-columns:1fr 1fr}
    }
    @media (max-width:620px){
      .app{padding:15px}
      .topbar{align-items:flex-start;flex-direction:column}
      .stats{grid-template-columns:1fr 1fr}
      .grid2,.toolbar,.url-row{grid-template-columns:1fr}
      .stat .value{font-size:24px}
    }
  </style>
</head>
<body>
<div class="app">
  <div class="topbar">
    <div class="brand">
      <h1>Job Hunt Tracker</h1>
      <p>Paste a job link, save the posting, and move it through your pipeline.</p>
    </div>
    <div class="top-actions">
      <button class="secondary" onclick="exportCSV()">Export CSV</button>
      <label class="button secondary" for="importFile">Import CSV</label>
      <input id="importFile" type="file" accept=".csv" hidden="" onchange="importCSV(event)">
      <button class="danger" onclick="clearAll()">Clear All</button>
    </div>
  </div>

  <section class="stats">
    <div class="stat"><div class="label">TOTAL</div><div class="value" id="statTotal">1</div></div>
    <div class="stat"><div class="label">SUBMITTED</div><div class="value" id="statSubmitted">1</div></div>
    <div class="stat"><div class="label">INTERVIEWING</div><div class="value" id="statInterview">0</div></div>
    <div class="stat"><div class="label">OFFERS</div><div class="value" id="statOffer">0</div></div>
    <div class="stat"><div class="label">REJECTED</div><div class="value" id="statRejected">0</div></div>
  </section>

  <div class="layout">
    <aside class="panel">
      <h2>Add a job</h2>
      <div class="sub">The tracker attempts to read the job title and company from the page. You can edit anything before saving.</div>

      <label>JOB LINK</label>
      <div class="url-row">
        <input id="jobUrl" type="url" placeholder="Paste LinkedIn, Greenhouse, Lever, Workday, etc.">
        <button class="secondary" onclick="pullJob()">Pull</button>
      </div>

      <div class="grid2">
        <div>
          <label>COMPANY</label>
          <input id="company" placeholder="Company name">
        </div>
        <div>
          <label>JOB TITLE</label>
          <input id="jobTitle" placeholder="Job title">
        </div>
      </div>

      <div class="grid2">
        <div>
          <label>LOCATION</label>
          <input id="location" placeholder="Remote / City">
        </div>
        <div>
          <label>WORK TYPE</label>
          <select id="workType">
            <option value="">Not specified</option>
            <option>Remote</option>
            <option>Hybrid</option>
            <option>On-site</option>
          </select>
        </div>
      </div>

      <div class="grid2">
        <div>
          <label>SALARY RANGE</label>
          <input id="salary" placeholder="$140K–$170K">
        </div>
        <div>
          <label>EXPECTED SALARY</label>
          <input id="expectedSalary" placeholder="$145K">
        </div>
      </div>

      <div class="grid2">
        <div>
          <label>STATUS</label>
          <select id="status">
            <option>Saved</option>
            <option selected="">Submitted</option>
            <option>Recruiter</option>
            <option>Interview</option>
            <option>Final</option>
            <option>Offer</option>
            <option>Rejected</option>
            <option>Withdrawn</option>
          </select>
        </div>
        <div>
          <label>DATE</label>
          <input id="dateApplied" type="date">
        </div>
      </div>

      <label>NOTES</label>
      <textarea id="notes" placeholder="Salary entered, recruiter name, why this role fits, follow-up date..."></textarea>

      <div class="form-actions">
        <button class="primary" onclick="saveJob()">Save Job</button>
        <button class="secondary" onclick="resetForm()">Reset</button>
      </div>

      <div class="hint">
        Some job sites block automatic reading. When that happens, the app still keeps the link and lets you enter the title manually. Nothing is uploaded; your tracker stays in this browser.
      </div>
    </aside>

    <main class="panel">
      <h2>Your applications</h2>
      <div class="sub">Use the quick buttons to update the application status. Data is stored in your browser using local storage.</div>

      <div class="toolbar">
        <input id="search" placeholder="Search company, title, notes..." oninput="render()">
        <select id="filterStatus" onchange="render()">
          <option value="">All statuses</option>
          <option>Saved</option><option>Submitted</option><option>Recruiter</option>
          <option>Interview</option><option>Final</option><option>Offer</option>
          <option>Rejected</option><option>Withdrawn</option>
        </select>
        <select id="sortBy" onchange="render()">
          <option value="newest">Newest first</option>
          <option value="oldest">Oldest first</option>
          <option value="company">Company A–Z</option>
          <option value="status">Status</option>
        </select>
        <button class="secondary" onclick="loadSampleData()">Load Current List</button>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
          <tr>
            <th>Company / Role</th>
            <th>Status</th>
            <th>Date</th>
            <th>Salary</th>
            <th>Location</th>
            <th>Notes</th>
            <th>Quick Update</th>
          </tr>
          </thead>
          <tbody id="jobRows">
      <tr>
        <td>
          <div class="company">Integer</div>
          <div class="title">US - Supply Chain Excellence Manager</div>
          <div class="meta">
            <a class="link" href="https://integer.wd1.myworkdayjobs.com/External/job/Remote---United-States/US---Supply-Chain-Excellence-Manager_R35570?source=LinkedIn" target="_blank" rel="noopener">Open job link</a>
          </div>
        </td>
        <td><span class="status status-Submitted">Submitted</span></td>
        <td>Jul 21, 2026</td>
        <td>
          <div>N/A</div>
          <div class="meta">Expected: $130k ~ $165k</div>
        </td>
        <td>
          
          
        </td>
        <td>Other: Travel (&lt;40%) may be required</td>
        <td>
          <div class="mini-actions">
            <button onclick="updateStatus(&#39;aff9290d-4e49-41dc-ac66-4d32d47cfba9&#39;,&#39;Submitted&#39;)">Submitted</button>
            <button onclick="updateStatus(&#39;aff9290d-4e49-41dc-ac66-4d32d47cfba9&#39;,&#39;Interview&#39;)">Interview</button>
            <button onclick="updateStatus(&#39;aff9290d-4e49-41dc-ac66-4d32d47cfba9&#39;,&#39;Rejected&#39;)">Rejected</button>
            <button onclick="editJob(&#39;aff9290d-4e49-41dc-ac66-4d32d47cfba9&#39;)">Edit</button>
            <button onclick="deleteJob(&#39;aff9290d-4e49-41dc-ac66-4d32d47cfba9&#39;)">Delete</button>
          </div>
        </td>
      </tr>
    </tbody>
        </table>
        <div id="emptyState" class="empty" style="display: none;">No jobs yet. Paste a link and save your first application.</div>
      </div>
      <div class="footer-note">Tip: export a CSV backup occasionally. Browsers are reliable—until they decide to become performance artists.</div>
    </main>
  </div>
</div>

<div class="toast" id="toast">Application saved.</div>

<script>
  const STORAGE_KEY = "pitching_the_wind_job_tracker_v1";
  let jobs = JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]");
  let editingId = null;

  const $ = id => document.getElementById(id);
  $("dateApplied").value = new Date().toISOString().slice(0,10);

  function persist(){
    localStorage.setItem(STORAGE_KEY, JSON.stringify(jobs));
    render();
  }

  function toast(msg){
    const t=$("toast");
    t.textContent=msg;
    t.classList.add("show");
    setTimeout(()=>t.classList.remove("show"),1800);
  }

  function cleanText(s){
    return (s || "").replace(/\s+/g," ").trim();
  }

  function deriveFromUrl(raw){
    try{
      const u=new URL(raw);
      const host=u.hostname.replace(/^www\./,"");
      let company="";
      let title="";
      const parts=u.pathname.split("/").filter(Boolean).map(decodeURIComponent);

      if(host.includes("lever.co") && parts.length>=2){
        company=titleCase(parts[0].replace(/[-_]/g," "));
      }else if(host.includes("greenhouse.io") && parts.length>=2){
        company=titleCase(parts[0].replace(/[-_]/g," "));
      }else if(host.includes("ashbyhq.com") && parts.length>=2){
        company=titleCase(parts[0].replace(/[-_]/g," "));
      }else if(host.includes("workdayjobs.com")){
        const sub=host.split(".")[0];
        company=titleCase(sub.replace(/[-_]/g," "));
      }else if(host.includes("linkedin.com")){
        const idx=parts.indexOf("view");
        if(idx>=0 && parts[idx+1]){
          title=titleCase(parts[idx+1].replace(/-\d+$/,"").replace(/[-_]/g," "));
        }
      }else{
        company=titleCase(host.split(".")[0].replace(/[-_]/g," "));
      }

      return {company,title};
    }catch(e){ return {company:"",title:""}; }
  }

  function titleCase(s){
    return s.replace(/\b\w/g,c=>c.toUpperCase());
  }

  async function pullJob(){
    const url=$("jobUrl").value.trim();
    if(!url){toast("Paste a job link first.");return;}

    const derived=deriveFromUrl(url);
    if(!$("company").value) $("company").value=derived.company;
    if(!$("jobTitle").value) $("jobTitle").value=derived.title;

    toast("Trying to read the posting...");
    try{
      const proxy="https://r.jina.ai/http://" + url.replace(/^https?:\/\//,"");
      const res=await fetch(proxy);
      if(!res.ok) throw new Error("Blocked");
      const text=await res.text();

      const titleMatch=text.match(/^Title:\s*(.+)$/mi);
      const descTitle=text.match(/^#\s+(.+)$/m);
      const companyMatch=text.match(/(?:Company|Organization):\s*(.+)$/mi);

      let pageTitle=cleanText(titleMatch?.[1] || descTitle?.[1] || "");
      if(pageTitle){
        pageTitle=pageTitle.replace(/\s+\|\s+.*$/,"").replace(/\s+-\s+Careers.*$/i,"");
        if(!$("jobTitle").value || $("jobTitle").value.length<5) $("jobTitle").value=pageTitle;
      }
      if(companyMatch && !$("company").value) $("company").value=cleanText(companyMatch[1]);
      toast("Posting details pulled. Please review.");
    }catch(e){
      toast("Site blocked auto-read. Manual edit is ready.");
    }
  }

  function saveJob(){
    const company=cleanText($("company").value);
    const jobTitle=cleanText($("jobTitle").value);
    const url=cleanText($("jobUrl").value);

    if(!company || !jobTitle){
      toast("Company and job title are required.");
      return;
    }

    const record={
      id: editingId || crypto.randomUUID(),
      company,
      title:jobTitle,
      url,
      location:cleanText($("location").value),
      workType:$("workType").value,
      salary:cleanText($("salary").value),
      expectedSalary:cleanText($("expectedSalary").value),
      status:$("status").value,
      date:$("dateApplied").value || new Date().toISOString().slice(0,10),
      notes:cleanText($("notes").value),
      createdAt: editingId ? (jobs.find(j=>j.id===editingId)?.createdAt || Date.now()) : Date.now(),
      updatedAt:Date.now()
    };

    if(editingId){
      jobs=jobs.map(j=>j.id===editingId?record:j);
      toast("Application updated.");
    }else{
      jobs.unshift(record);
      toast("Application saved.");
    }
    persist();
    resetForm();
  }

  function resetForm(){
    editingId=null;
    ["jobUrl","company","jobTitle","location","salary","expectedSalary","notes"].forEach(id=>$(id).value="");
    $("workType").value="";
    $("status").value="Submitted";
    $("dateApplied").value=new Date().toISOString().slice(0,10);
  }

  function editJob(id){
    const j=jobs.find(x=>x.id===id);
    if(!j)return;
    editingId=id;
    $("jobUrl").value=j.url||"";
    $("company").value=j.company||"";
    $("jobTitle").value=j.title||"";
    $("location").value=j.location||"";
    $("workType").value=j.workType||"";
    $("salary").value=j.salary||"";
    $("expectedSalary").value=j.expectedSalary||"";
    $("status").value=j.status||"Saved";
    $("dateApplied").value=j.date||"";
    $("notes").value=j.notes||"";
    window.scrollTo({top:0,behavior:"smooth"});
  }

  function updateStatus(id,status){
    const j=jobs.find(x=>x.id===id);
    if(!j)return;
    j.status=status;
    j.updatedAt=Date.now();
    persist();
    toast("Status changed to "+status+".");
  }

  function deleteJob(id){
    if(!confirm("Delete this application?"))return;
    jobs=jobs.filter(j=>j.id!==id);
    persist();
  }

  function render(){
    const q=$("search").value.toLowerCase().trim();
    const status=$("filterStatus").value;
    const sort=$("sortBy").value;

    let list=jobs.filter(j=>{
      const hay=[j.company,j.title,j.notes,j.location,j.salary,j.expectedSalary].join(" ").toLowerCase();
      return (!q || hay.includes(q)) && (!status || j.status===status);
    });

    list.sort((a,b)=>{
      if(sort==="oldest") return new Date(a.date)-new Date(b.date);
      if(sort==="company") return a.company.localeCompare(b.company);
      if(sort==="status") return a.status.localeCompare(b.status);
      return new Date(b.date)-new Date(a.date);
    });

    $("jobRows").innerHTML=list.map(j=>`
      <tr>
        <td>
          <div class="company">${escapeHtml(j.company)}</div>
          <div class="title">${escapeHtml(j.title)}</div>
          <div class="meta">
            ${j.url?`<a class="link" href="${escapeAttr(j.url)}" target="_blank" rel="noopener">Open job link</a>`:"No link saved"}
          </div>
        </td>
        <td><span class="status status-${j.status}">${escapeHtml(j.status)}</span></td>
        <td>${formatDate(j.date)}</td>
        <td>
          ${j.salary?`<div>${escapeHtml(j.salary)}</div>`:""}
          ${j.expectedSalary?`<div class="meta">Expected: ${escapeHtml(j.expectedSalary)}</div>`:""}
        </td>
        <td>
          ${escapeHtml(j.location||"")}
          ${j.workType?`<div class="meta">${escapeHtml(j.workType)}</div>`:""}
        </td>
        <td>${escapeHtml(j.notes||"")}</td>
        <td>
          <div class="mini-actions">
            <button onclick="updateStatus('${j.id}','Submitted')">Submitted</button>
            <button onclick="updateStatus('${j.id}','Interview')">Interview</button>
            <button onclick="updateStatus('${j.id}','Rejected')">Rejected</button>
            <button onclick="editJob('${j.id}')">Edit</button>
            <button onclick="deleteJob('${j.id}')">Delete</button>
          </div>
        </td>
      </tr>
    `).join("");

    $("emptyState").style.display=list.length?"none":"block";
    updateStats();
  }

  function updateStats(){
    $("statTotal").textContent=jobs.length;
    $("statSubmitted").textContent=jobs.filter(j=>j.status==="Submitted").length;
    $("statInterview").textContent=jobs.filter(j=>["Recruiter","Interview","Final"].includes(j.status)).length;
    $("statOffer").textContent=jobs.filter(j=>j.status==="Offer").length;
    $("statRejected").textContent=jobs.filter(j=>j.status==="Rejected").length;
  }

  function formatDate(s){
    if(!s)return"";
    const d=new Date(s+"T00:00:00");
    return d.toLocaleDateString(undefined,{month:"short",day:"numeric",year:"numeric"});
  }

  function escapeHtml(s){
    return String(s??"").replace(/[&<>"']/g,m=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[m]));
  }
  function escapeAttr(s){return escapeHtml(s)}

  function exportCSV(){
    const headers=["Company","Job Title","URL","Location","Work Type","Salary Range","Expected Salary","Status","Date","Notes"];
    const rows=jobs.map(j=>[j.company,j.title,j.url,j.location,j.workType,j.salary,j.expectedSalary,j.status,j.date,j.notes]);
    const csv=[headers,...rows].map(r=>r.map(v=>`"${String(v??"").replace(/"/g,'""')}"`).join(",")).join("\n");
    const blob=new Blob([csv],{type:"text/csv;charset=utf-8"});
    const a=document.createElement("a");
    a.href=URL.createObjectURL(blob);
    a.download="job_tracker_backup.csv";
    a.click();
    URL.revokeObjectURL(a.href);
  }

  function parseCSV(text){
    const rows=[];let row=[],cell="",quoted=false;
    for(let i=0;i<text.length;i++){
      const c=text[i],n=text[i+1];
      if(c==='"' && quoted && n==='"'){cell+='"';i++}
      else if(c==='"'){quoted=!quoted}
      else if(c==="," && !quoted){row.push(cell);cell=""}
      else if((c==="\n"||c==="\r")&&!quoted){
        if(c==="\r"&&n==="\n")i++;
        row.push(cell);rows.push(row);row=[];cell="";
      }else cell+=c;
    }
    if(cell||row.length){row.push(cell);rows.push(row)}
    return rows;
  }

  async function importCSV(event){
    const file=event.target.files[0];if(!file)return;
    const text=await file.text();
    const rows=parseCSV(text);
    if(rows.length<2){toast("CSV is empty.");return}
    const data=rows.slice(1).filter(r=>r.some(Boolean)).map(r=>({
      id:crypto.randomUUID(),
      company:r[0]||"",title:r[1]||"",url:r[2]||"",location:r[3]||"",
      workType:r[4]||"",salary:r[5]||"",expectedSalary:r[6]||"",
      status:r[7]||"Saved",date:r[8]||new Date().toISOString().slice(0,10),
      notes:r[9]||"",createdAt:Date.now(),updatedAt:Date.now()
    }));
    jobs=[...data,...jobs];
    persist();toast(data.length+" applications imported.");
    event.target.value="";
  }

  function clearAll(){
    if(!confirm("Clear every job from this browser? Export a CSV first if you need a backup."))return;
    jobs=[];persist();toast("Tracker cleared.");
  }

